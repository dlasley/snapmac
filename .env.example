# Remote repository where your snapshots will be pushed.
# Create a private repo to store your snapshots, then set this URL.
# push-snapshot.sh will configure the git remote automatically on first run.
SNAPMAC_REMOTE_REPO=https://github.com/dlasley/snapmac.git

# Set to "true" to always pin exact package versions when generating snapshots.
# Equivalent to passing --version=exact to snapshot.sh
SNAPMAC_PIN_VERSIONS=false
